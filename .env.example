# Project paths
RAG_BASE_DIR=.
PYTHONPATH=.
HF_ENDPOINT=https://hf-mirror.com

# API service
SERVICE_VERSION=0.2.0
ENABLE_METRICS=1
RAG_API_PORT=8080
RAG_MAX_INFLIGHT_REQUESTS=2
RAG_BM25_TOPK=10
RAG_MILVUS_TOPK=10
RAG_RERANK_TOPK=5
RAG_WARMUP_QUERY=这是一条测试数据
RAG_WARMUP_TOPK=3
RAG_EMBEDDING_DEVICE=cuda
RAG_RERANKER_DEVICE=cuda

# Local OpenAI-compatible model service served by vLLM
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_API_KEY=EMPTY
LOCAL_LLM_MODEL=qwen3_lora_sft_int4
LOCAL_LLM_MODEL_HOST_PATH=./LLaMA-Factory-main/output/qwen3_lora_sft_int4
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_MAX_RETRIES=2
LOCAL_LLM_MAX_TOKENS=4096

# Optional cloud LLM config for data generation / cleaning
DOUBAO_API_KEY=replace-with-your-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_NAME=replace-with-your-endpoint-id

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB_NAME=mydatabase
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin
MONGO_MAX_POOL_SIZE=100
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=3000

# vLLM startup parameters used by scripts/start_services.sh
VLLM_PORT=8000
VLLM_MODEL_PATH=LLaMA-Factory-main/output/qwen3_lora_sft_int4
VLLM_SERVED_MODEL_NAME=qwen3_lora_sft_int4
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.7
VLLM_TENSOR_PARALLEL_SIZE=1
CUDA_VISIBLE_DEVICES=0
RAG_API_CUDA_VISIBLE_DEVICES=0
START_MONGODB=0
MONGODB_BIN=mongodb-7.0.20/bin/mongod
MONGODB_DBPATH=data/mongodb/data
MONGODB_LOGPATH=data/mongodb/log/mongodb.log
MONGO_BIND_IP=0.0.0.0
